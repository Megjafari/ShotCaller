@page "/predict"
@using frontend.Models
@inject HttpClient Http

<h1>Predict</h1>

<div style="margin-bottom:1rem">
    <label>Your name: </label>
    <input @bind="userName" placeholder="Enter your name" />
    <button @onclick="Load">Load my predictions</button>
</div>

@if (loading)
{
    <p>Loading...</p>
}
else if (error)
{
    <p style="color:red">Could not reach the API. Is it running?</p>
}
else if (matches is not null)
{
    <table>
        <thead>
            <tr><th>Match</th><th>Kickoff</th><th>Prediction</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var m in matches)
            {
                var locked = m.KickoffUtc <= DateTime.UtcNow;
                var existing = myPredictions.FirstOrDefault(p => p.MatchId == m.Id);
                <tr>
                    <td>@m.HomeTeam – @m.AwayTeam</td>
                    <td>@m.KickoffUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @if (locked)
                        {
                            <span>Kickoff passed</span>
                        }
                        else
                        {
                            <input type="number" min="0" style="width:3rem" @bind="homeScores[m.Id]" />
                            <span> – </span>
                            <input type="number" min="0" style="width:3rem" @bind="awayScores[m.Id]" />
                        }
                    </td>
                    <td>
                        @if (!locked && existing is null)
                        {
                            <button @onclick="() => Create(m.Id)">Save</button>
                        }
                        else if (!locked && existing is not null)
                        {
                            <button @onclick="() => Update(existing.Id, m.Id)">Update</button>
                            <button @onclick="() => Delete(existing.Id)">Delete</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(message))
{
    <p>@message</p>
}

@code {
    private List<MatchModel>? matches;
    private List<PredictionModel> myPredictions = new();
    private bool loading = false;
    private bool error = false;
    private string userName = "";
    private string message = "";
    private Dictionary<int, int> homeScores = new();
    private Dictionary<int, int> awayScores = new();

    private async Task Load()
    {
        if (string.IsNullOrWhiteSpace(userName))
        {
            message = "Enter your name first.";
            return;
        }

        loading = true;
        error = false;
        message = "";

        try
        {
            matches = await Http.GetFromJsonAsync<List<MatchModel>>("api/matches");
            myPredictions = await Http.GetFromJsonAsync<List<PredictionModel>>($"api/predictions/user/{userName}") ?? new();

            foreach (var m in matches!)
            {
                var existing = myPredictions.FirstOrDefault(p => p.MatchId == m.Id);
                homeScores[m.Id] = existing?.PredictedHomeScore ?? 0;
                awayScores[m.Id] = existing?.PredictedAwayScore ?? 0;
            }
        }
        catch
        {
            error = true;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Create(int matchId)
    {
        var dto = new CreatePredictionModel
        {
            UserName = userName,
            MatchId = matchId,
            PredictedHomeScore = homeScores.GetValueOrDefault(matchId),
            PredictedAwayScore = awayScores.GetValueOrDefault(matchId)
        };
        await Send(() => Http.PostAsJsonAsync("api/predictions", dto), "Prediction saved!");
    }

    private async Task Update(int predictionId, int matchId)
    {
        var dto = new UpdatePredictionModel
        {
            PredictedHomeScore = homeScores.GetValueOrDefault(matchId),
            PredictedAwayScore = awayScores.GetValueOrDefault(matchId)
        };
        await Send(() => Http.PutAsJsonAsync($"api/predictions/{predictionId}", dto), "Prediction updated!");
    }

    private async Task Delete(int predictionId)
    {
        await Send(() => Http.DeleteAsync($"api/predictions/{predictionId}"), "Prediction deleted!");
    }

    private async Task Send(Func<Task<HttpResponseMessage>> action, string successMessage)
    {
        try
        {
            var response = await action();
            message = response.IsSuccessStatusCode ? successMessage : "Something went wrong.";
            await Load(); // ladda om så listan stämmer
        }
        catch
        {
            message = "Could not reach the API.";
        }
    }
}