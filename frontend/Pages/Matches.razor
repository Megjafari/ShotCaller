@page "/matches"
@using frontend.Models
@inject HttpClient Http

<h1>Matches</h1>

@if (loading)
{
    <p>Loading matches...</p>
}
else if (error)
{
    <p style="color:#ff5c5c">Could not load matches. Is the API running?</p>
}
else if (matches is null || matches.Count == 0)
{
    <p>No matches found.</p>
}
else
{
    <div class="card-grid">
        @foreach (var m in matches)
        {
            <div class="match-card">
                <span class="group-tag">Group @m.Group</span>
                <span class="teams">@m.HomeTeam – @m.AwayTeam</span>
                <span class="meta">@m.KickoffUtc.ToString("yyyy-MM-dd HH:mm")</span>
                @if (m.HomeScore is not null)
                {
                    <span class="score">@m.HomeScore – @m.AwayScore</span>
                }
                else
                {
                    <span class="locked">Not played</span>
                }
            </div>
        }
    </div>
}

@code {
    private List<MatchModel>? matches;
    private bool loading = true;
    private bool error = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            matches = await Http.GetFromJsonAsync<List<MatchModel>>("api/matches");
        }
        catch
        {
            error = true;
        }
        finally
        {
            loading = false;
        }
    }
}